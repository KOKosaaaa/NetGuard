    <!-- Onboarding -->
    <string name="onb_lang_title">Choisissez votre langue</string>
    <string name="onb_lang_subtitle">Modifiable plus tard dans Paramètres</string>
    <string name="onb_skip">Passer</string>
    <string name="onb_next">Suivant</string>
    <string name="onb_back">Retour</string>
    <string name="onb_finish">Terminer</string>
    <string name="onb_welcome_title">Bienvenue sur NetGuard</string>
    <string name="onb_welcome_subtitle">Accès chiffré rapide à votre façon</string>
    <string name="onb_welcome_body">NetGuard est un client moderne basé sur xray-core avec routage sélectif, test de vitesse, kill switch, protection contre le Wi-Fi jumeau et statistiques de trafic. La configuration prend environ une minute — tout peut être modifié plus tard.</string>
    <string name="onb_feature_trigger_title">⚡ Mode déclencheur</string>
    <string name="onb_feature_trigger">Le VPN s\'active uniquement à l\'ouverture d\'une de vos apps choisies, et s\'arrête en silence à la fermeture. Banque, cartes, livraison — tout le reste reste sur la connexion normale.</string>
    <string name="onb_feature_perapp_title">🎯 VPN par app</string>
    <string name="onb_feature_perapp">Liste blanche/noire classique d\'apps qui passent par le tunnel.</string>
    <string name="onb_feature_protocols_title">🔐 Protocoles et sécurité</string>
    <string name="onb_feature_protocols">VLESS, VMess, Trojan, Shadowsocks, Hysteria2. Reality, XTLS-Vision, TLS-Fragment, DNS sur HTTPS, kill switch — tout est pris en charge.</string>
    <string name="onb_mode_title">Comment NetGuard doit-il router le trafic ?</string>
    <string name="onb_mode_subtitle">Modifiable plus tard dans Paramètres</string>
    <string name="onb_mode_global">VPN global</string>
    <string name="onb_mode_global_desc">Toutes les apps passent par le VPN. Mode standard.</string>
    <string name="onb_mode_trigger">Mode déclencheur (recommandé)</string>
    <string name="onb_mode_trigger_desc">⚠ SEULES les apps de votre liste de déclencheurs passent par le VPN — le tunnel s\'active à l\'ouverture et s\'arrête à la fermeture. Tout le reste (banque, cartes, navigateur) reste sur la connexion normale et n\'utilise JAMAIS le VPN.</string>
    <string name="onb_mode_perapp">VPN par app</string>
    <string name="onb_mode_perapp_desc">Choisissez manuellement quelles apps passent par le VPN.</string>
    <string name="onb_mode_skip">Décider plus tard</string>
    <string name="onb_mode_skip_desc">Passer — je configurerai depuis Paramètres.</string>
    <string name="onb_vpn_title">Autoriser la connexion VPN</string>
    <string name="onb_vpn_body">Android requiert une autorisation explicite pour créer un tunnel VPN. NetGuard ne collecte ni ne transmet aucun trafic que vous n\'avez pas configuré.</string>
    <string name="onb_vpn_grant">Accorder la permission VPN</string>
    <string name="onb_vpn_granted">Permission VPN accordée ✓</string>
    <string name="onb_vpn_denied">Sans permission le tunnel ne fonctionnera pas — vous pouvez l\'accorder plus tard</string>
    <string name="onb_usage_title">Accès aux statistiques d\'utilisation</string>
    <string name="onb_usage_body">Le mode déclencheur doit détecter quand une app choisie passe au premier plan. Android l\'expose via Accès aux statistiques — NetGuard ne lit que le nom de paquet et ne stocke rien.</string>
    <string name="onb_usage_grant">Ouvrir les paramètres d\'accès</string>
    <string name="onb_usage_granted">Accès accordé ✓</string>
    <string name="onb_done_title">Tout est prêt</string>
    <string name="onb_done_body">C\'est prêt. Sur l\'écran d\'accueil, touchez le grand interrupteur pour connecter, ou ouvrez Serveurs → ＋ pour ajouter plus de profils. Les abonnements se mettent à jour automatiquement.</string>
    <string name="onb_profile_title">Ajoutez votre premier serveur</string>
    <string name="onb_profile_body">Collez un lien vless://, vmess://, trojan://, ss:// ou hy2://. Vous pouvez aussi passer et ajouter des serveurs plus tard.</string>
    <string name="onb_profile_paste">Coller depuis le presse-papiers</string>
    <string name="onb_profile_hint">Collez un lien de connexion…</string>
    <string name="onb_profile_import">Importer</string>
    <string name="onb_profile_added">%d serveur(s) importé(s) ✓</string>
    <string name="onb_profile_error">Impossible d\'analyser : %s</string>
    <string name="onb_profile_empty">Presse-papiers vide</string>
    <string name="onb_profile_skip">J\'ajouterai un serveur plus tard</string>
    <string name="trigger_strict_mode">Mode liste autorisée stricte</string>
    <string name="trigger_strict_mode_desc">ON : seules les apps déclencheurs passent par le VPN, sans alternative. OFF : les apps déclencheurs décident seulement QUAND le tunnel s\'active — le routage suit vos paramètres Par-App / Global normaux.</string>
    <string name="trigger_dualapp_warning">⚠ Les apps clonées (MIUI Dual Apps / Samsung Dual Messenger / Parallel Space) ne sont pas prises en charge par l\'API VPN d\'Android.</string>
    <string name="trigger_dualapp_more">Pourquoi ?</string>
    <string name="trigger_dualapp_explain_title">Apps clonées et l\'API VPN</string>
    <string name="trigger_dualapp_explain_body">Limitation Android : un VPN système exécuté pour l\'utilisateur principal ne peut autoriser que les apps de cet utilisateur. Une app clonée s\'exécute comme un utilisateur séparé (souvent UID 999000+ sur MIUI) — son UID n\'est pas dans la liste autorisée, le trafic est rejeté.\n\nSolutions :\n• Utilisez le Telegram original (non cloné) en mode déclencheur.\n• Désactivez « Bloquer les connexions sans VPN » dans les paramètres Android.\n• Ajoutez le clone séparément si votre système l\'expose (rare).</string>
</resources>
