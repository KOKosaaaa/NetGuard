    <string name="onb_finish">Concluir</string>
    <string name="onb_welcome_title">Bem-vindo ao NetGuard</string>
    <string name="onb_welcome_subtitle">Acesso criptografado rápido do seu jeito</string>
    <string name="onb_welcome_body">NetGuard é um cliente moderno baseado em xray-core com roteamento seletivo, teste de velocidade, kill switch, proteção contra Wi-Fi gêmeo e estatísticas de tráfego. A configuração leva cerca de um minuto — tudo pode ser alterado depois.</string>
    <string name="onb_feature_trigger_title">⚡ Modo gatilho</string>
    <string name="onb_feature_trigger">A VPN ativa apenas quando você abre um dos apps escolhidos e desliga ao fechar. Banco, mapas, entrega — todo o resto fica na conexão normal.</string>
    <string name="onb_feature_perapp_title">🎯 VPN por app</string>
    <string name="onb_feature_perapp">Whitelist/blacklist clássica de apps que passam pelo túnel.</string>
    <string name="onb_feature_protocols_title">🔐 Protocolos e segurança</string>
    <string name="onb_feature_protocols">VLESS, VMess, Trojan, Shadowsocks, Hysteria2. Reality, XTLS-Vision, TLS-Fragment, DNS sobre HTTPS, kill switch — tudo suportado.</string>
    <string name="onb_mode_title">Como o NetGuard deve rotear o tráfego?</string>
    <string name="onb_mode_subtitle">Pode ser alterado depois em Configurações</string>
    <string name="onb_mode_global">VPN global</string>
    <string name="onb_mode_global_desc">Todos os apps passam pela VPN. Modo padrão.</string>
    <string name="onb_mode_trigger">Modo gatilho (recomendado)</string>
    <string name="onb_mode_trigger_desc">⚠ APENAS os apps na sua lista de gatilhos passam pela VPN — o túnel ativa ao abrir e para ao fechar. Todo o resto (banco, mapas, navegador) fica na conexão normal e NUNCA usa a VPN.</string>
    <string name="onb_mode_perapp">VPN por app</string>
    <string name="onb_mode_perapp_desc">Escolha manualmente quais apps passam pela VPN.</string>
    <string name="onb_mode_skip">Decidir depois</string>
    <string name="onb_mode_skip_desc">Pular — vou configurar nas Configurações.</string>
    <string name="onb_vpn_title">Permitir conexão VPN</string>
    <string name="onb_vpn_body">O Android exige permissão explícita para criar um túnel VPN. O NetGuard não coleta nem transmite tráfego que você não configurou.</string>
    <string name="onb_vpn_grant">Conceder permissão VPN</string>
    <string name="onb_vpn_granted">Permissão VPN concedida ✓</string>
    <string name="onb_vpn_denied">Sem permissão o túnel não funcionará — você pode conceder depois</string>
    <string name="onb_usage_title">Acesso de uso para o modo gatilho</string>
    <string name="onb_usage_body">O modo gatilho precisa detectar quando um app escolhido vai para o primeiro plano. O Android expõe isso via Acesso de Uso — o NetGuard lê apenas o nome do pacote e não armazena nada.</string>
    <string name="onb_usage_grant">Abrir configurações de Acesso de Uso</string>
    <string name="onb_usage_granted">Acesso concedido ✓</string>
    <string name="onb_done_title">Tudo pronto</string>
    <string name="onb_done_body">Pronto. Na tela inicial toque no botão grande para conectar, ou abra Servidores → ＋ para adicionar mais perfis. Assinaturas atualizam automaticamente.</string>
    <string name="onb_profile_title">Adicione seu primeiro servidor</string>
    <string name="onb_profile_body">Cole um link vless://, vmess://, trojan://, ss:// ou hy2://. Você também pode pular e adicionar servidores depois.</string>
    <string name="onb_profile_paste">Colar da área de transferência</string>
    <string name="onb_profile_hint">Cole um link de conexão…</string>
    <string name="onb_profile_import">Importar</string>
    <string name="onb_profile_added">%d servidor(es) importado(s) ✓</string>
    <string name="onb_profile_error">Não foi possível analisar: %s</string>
    <string name="onb_profile_empty">Área de transferência vazia</string>
    <string name="onb_profile_skip">Vou adicionar servidor depois</string>
    <string name="trigger_strict_mode">Modo lista permitida estrita</string>
    <string name="trigger_strict_mode_desc">ON: apenas apps gatilho passam pela VPN, sem alternativa. OFF: apps gatilho apenas decidem QUANDO o túnel ativa — o roteamento segue suas configurações Por-App / Globais normais.</string>
    <string name="trigger_dualapp_warning">⚠ Apps clonados (MIUI Dual Apps / Samsung Dual Messenger / Parallel Space) não são suportados pela API VPN do Android.</string>
    <string name="trigger_dualapp_more">Por quê?</string>
    <string name="trigger_dualapp_explain_title">Apps clonados e a API VPN</string>
    <string name="trigger_dualapp_explain_body">Limitação do Android: uma VPN do sistema rodando como usuário principal só pode permitir apps desse usuário. Um app clonado roda como usuário separado (geralmente UID 999000+ no MIUI) — seu UID não está na lista permitida e o tráfego é descartado.\n\nSoluções:\n• Use o Telegram original (não clonado) no modo gatilho.\n• Desative «Bloquear conexões sem VPN» nas configurações do Android.\n• Adicione o clone separadamente se seu sistema o expõe (raro).</string>
</resources>
