<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Compact toggle card. Always visible, gives the user a glance at the
         current state (Trigger ON/OFF, app count) and a clear chevron to
         reveal the full controls panel. Replaces the easy-to-miss text
         button that used to sit between the header and the apps list. -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_options_toggle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:paddingVertical="12dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="@string/trigger_title"
                android:src="@drawable/ic_settings"
                app:tint="?attr/colorOnSurfaceVariant" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/trigger_options_card_title"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_options_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/iv_options_chevron"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/trigger_expand"
                android:rotation="0"
                android:src="@drawable/ic_chevron_down"
                app:tint="?attr/colorOnSurfaceVariant" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Top section: collapsible explainer + switches + permissions.
         Default collapsed (visibility="gone") so the apps list gets the
         room. Tap the card above to expand. -->
    <LinearLayout
        android:id="@+id/header_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_explainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:text="@string/trigger_explainer"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_dualapp_warning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="6dp"
            app:cardBackgroundColor="?attr/colorErrorContainer"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tv_dualapp_warning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/trigger_dualapp_warning"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnErrorContainer" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_dualapp_more"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:minHeight="0dp"
                    android:paddingVertical="4dp"
                    android:text="@string/trigger_dualapp_more"
                    android:textColor="?attr/colorOnErrorContainer"
                    android:textSize="12sp"
                    style="@style/Widget.Material3.Button.TextButton" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/sw_trigger_enable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:minHeight="48dp"
            android:text="@string/trigger_enable"
            android:textSize="15sp"
            app:thumbTint="@color/trigger_switch_thumb"
            app:trackTint="@color/trigger_switch_track"
            app:trackDecorationTint="@color/trigger_switch_track_decoration" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/sw_trigger_auto_stop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:minHeight="48dp"
            android:text="@string/trigger_auto_stop"
            android:textSize="15sp"
            app:thumbTint="@color/trigger_switch_thumb"
            app:trackTint="@color/trigger_switch_track"
            app:trackDecorationTint="@color/trigger_switch_track_decoration" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/sw_trigger_strict"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:minHeight="48dp"
            android:text="@string/trigger_strict_mode"
            android:textSize="15sp"
            app:thumbTint="@color/trigger_switch_thumb"
            app:trackTint="@color/trigger_switch_track"
            app:trackDecorationTint="@color/trigger_switch_track_decoration" />

        <TextView
            android:id="@+id/tv_strict_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="8dp"
            android:text="@string/trigger_strict_mode_desc"
            android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_grant_permission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="6dp"
            android:text="@string/trigger_grant_permission"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_open_vpn_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="4dp"
            android:text="@string/trigger_open_vpn_settings"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <View android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:background="?attr/colorOutlineVariant" />
    </LinearLayout>

    <!-- Legacy id kept for binding compatibility but hidden — the new card
         above replaces it as the visible toggle. -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_toggle_header"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- Search row -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/search_apps"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="4dp"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:imeOptions="actionSearch" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Tight row: system apps toggle + selected count -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:gravity="center_vertical">

        <CheckBox
            android:id="@+id/cb_system_apps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/show_system_apps"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_selected_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress_loading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone"
        style="?android:attr/progressBarStyleHorizontal" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_apps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/save"
        android:layout_margin="8dp" />
</LinearLayout>
