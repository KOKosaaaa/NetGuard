<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Top section: collapsible explainer + switches + permissions -->
    <LinearLayout
        android:id="@+id/header_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_explainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:text="@string/trigger_explainer"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/sw_trigger_enable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:minHeight="48dp"
            android:text="@string/trigger_enable"
            android:textSize="15sp"
            app:thumbTint="@color/trigger_switch_thumb"
            app:trackTint="@color/trigger_switch_track"
            app:trackDecorationTint="@color/trigger_switch_track_decoration" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/sw_trigger_auto_stop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:minHeight="48dp"
            android:text="@string/trigger_auto_stop"
            android:textSize="15sp"
            app:thumbTint="@color/trigger_switch_thumb"
            app:trackTint="@color/trigger_switch_track"
            app:trackDecorationTint="@color/trigger_switch_track_decoration" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_grant_permission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="6dp"
            android:text="@string/trigger_grant_permission"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_open_vpn_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="4dp"
            android:text="@string/trigger_open_vpn_settings"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <View android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:background="?attr/colorOutlineVariant" />
    </LinearLayout>

    <!-- Compact toggle button: collapse/expand header to give the list more room -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_toggle_header"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginHorizontal="8dp"
        android:layout_marginVertical="2dp"
        android:textSize="11sp"
        android:text="@string/trigger_collapse"
        style="@style/Widget.Material3.Button.TextButton" />

    <!-- Search row -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/search_apps"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="4dp"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:imeOptions="actionSearch" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Tight row: system apps toggle + selected count -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:gravity="center_vertical">

        <CheckBox
            android:id="@+id/cb_system_apps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/show_system_apps"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_selected_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress_loading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone"
        style="?android:attr/progressBarStyleHorizontal" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_apps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/save"
        android:layout_margin="8dp" />
</LinearLayout>
