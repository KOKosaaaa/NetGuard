<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="8dp"
    android:background="@drawable/bg_widget">

    <ImageView
        android:id="@+id/iv_widget_icon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_power"
        android:contentDescription="@string/connect"
        android:background="@drawable/bg_button_disconnected"
        android:layout_marginEnd="10dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_widget_server"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_profile_selected"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_widget_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_disconnected"
            android:textSize="11sp"
            android:textColor="#B0FFFFFF"
            android:maxLines="1" />

    </LinearLayout>

</LinearLayout>
