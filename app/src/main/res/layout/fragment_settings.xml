<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ===== THEME ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/theme"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_theme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/theme_dark"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?attr/colorOutline" android:layout_marginVertical="16dp" />

        <!-- ===== LANGUAGE ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/language"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_language"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/language_system"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?attr/colorOutline" android:layout_marginVertical="16dp" />

        <!-- ===== FEATURES ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/features"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <CheckBox android:id="@+id/cb_connection_map" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="@string/show_connection_map" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/connection_map_desc" android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginStart="32dp"
            android:layout_marginBottom="4dp" />

        <CheckBox android:id="@+id/cb_speed_test" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="@string/show_speed_test" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/speed_test_desc" android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginStart="32dp"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_traffic_stats_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/traffic_stats"
            style="@style/Widget.Material3.Button.OutlinedButton" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/traffic_stats_desc" android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginStart="32dp"
            android:layout_marginBottom="4dp" />

        <CheckBox android:id="@+id/cb_auto_connect_wifi" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="@string/auto_connect_wifi" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/auto_connect_wifi_desc" android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginStart="32dp"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_trusted_wifi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/trusted_wifi"
            android:layout_marginStart="32dp"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?attr/colorOutline" android:layout_marginVertical="16dp" />

        <!-- ===== TLS FRAGMENT ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tls_fragment"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tls_fragment_desc"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="8dp" />

        <CheckBox
            android:id="@+id/cb_tls_fragment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tls_fragment_enable" />

        <LinearLayout
            android:id="@+id/ll_tls_fragment_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/tls_fragment_packets">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_tls_packets"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="tlshello" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/tls_fragment_length">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_tls_length"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="100-200" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/tls_fragment_interval">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_tls_interval"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="10-20" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?attr/colorOutline" android:layout_marginVertical="16dp" />

        <!-- ===== BYPASS LIST ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bypass_list"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bypass_list_desc"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/bypass_domains_hint">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_bypass_domains"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:gravity="top" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="@string/bypass_ips_hint">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_bypass_ips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:gravity="top" />
        </com.google.android.material.textfield.TextInputLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?attr/colorOutline" android:layout_marginVertical="16dp" />

        <!-- ===== ROUTING ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/routing"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/routing_desc"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/rg_routing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RadioButton android:id="@+id/rb_global" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="@string/routing_global" />
            <RadioButton android:id="@+id/rb_rules" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="@string/routing_rules" />
            <RadioButton android:id="@+id/rb_direct" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="@string/routing_direct" />
        </RadioGroup>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?attr/colorOutline" android:layout_marginVertical="16dp" />

        <!-- ===== DNS ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DNS"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dns_desc"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/primary_dns">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_primary_dns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/secondary_dns">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_secondary_dns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ===== NETWORK OPTIONS ===== -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?attr/colorOutline" android:layout_marginVertical="16dp" />

        <CheckBox android:id="@+id/cb_doh" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="@string/doh" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/doh_desc" android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginStart="32dp"
            android:layout_marginBottom="4dp" />

        <CheckBox android:id="@+id/cb_bypass_lan" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="@string/bypass_lan" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/bypass_lan_desc" android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginStart="32dp"
            android:layout_marginBottom="4dp" />

        <CheckBox android:id="@+id/cb_ipv6" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="@string/enable_ipv6" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/ipv6_desc" android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginStart="32dp"
            android:layout_marginBottom="4dp" />

        <CheckBox android:id="@+id/cb_speed_notification" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="@string/show_speed_notification" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/speed_notif_desc" android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginStart="32dp"
            android:layout_marginBottom="4dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?attr/colorOutline" android:layout_marginVertical="16dp" />

        <!-- ===== KILL SWITCH ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/kill_switch"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/kill_switch_full_desc"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_kill_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/open_vpn_settings"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?attr/colorOutline" android:layout_marginVertical="16dp" />

        <!-- ===== PER-APP VPN ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/per_app_vpn"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/per_app_desc"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/rg_per_app_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RadioButton android:id="@+id/rb_per_app_disabled" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="@string/per_app_disabled" />
            <RadioButton android:id="@+id/rb_per_app_whitelist" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="@string/per_app_whitelist" />
            <RadioButton android:id="@+id/rb_per_app_blacklist" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="@string/per_app_blacklist" />
        </RadioGroup>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_select_apps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/select_apps"
            android:layout_marginTop="8dp"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?attr/colorOutline" android:layout_marginVertical="16dp" />

        <!-- ===== SECURITY TEST ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/security_self_test"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/security_test_desc"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_security_test"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/run_security_test" />

        <ProgressBar
            android:id="@+id/progress_security"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/ll_security_results"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="8dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?attr/colorOutline" android:layout_marginVertical="16dp" />

        <!-- ===== EXPORT / IMPORT ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/export_import"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/export_import_desc"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_export"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/export_config"
                android:layout_marginEnd="4dp"
                android:filterTouchesWhenObscured="true"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_import"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/import_config"
                android:layout_marginStart="4dp"
                android:filterTouchesWhenObscured="true"
                style="@style/Widget.Material3.Button.OutlinedButton" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?attr/colorOutline" android:layout_marginVertical="16dp" />

        <!-- ===== BACKUP / RESTORE ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/backup_restore"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/backup_restore_desc"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_backup_file"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/backup_to_file"
                android:layout_marginEnd="4dp"
                android:filterTouchesWhenObscured="true"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_restore_file"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/restore_from_file"
                android:layout_marginStart="4dp"
                android:filterTouchesWhenObscured="true"
                style="@style/Widget.Material3.Button.OutlinedButton" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?attr/colorOutline" android:layout_marginVertical="16dp" />

        <!-- ===== ABOUT ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_created_by"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/created_by"
                android:textSize="14sp"
                android:textColor="?attr/colorPrimary"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
