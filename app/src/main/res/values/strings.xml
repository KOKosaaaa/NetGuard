    <!-- Trigger settings UI -->
    <string name="trigger_title">App-launch trigger</string>
    <string name="trigger_subtitle">VPN turns on only for the apps you pick</string>
    <string name="trigger_enable">Enable trigger mode</string>
    <string name="trigger_explainer">Only the apps you pick go through the VPN. Every other app (banking, maps, your usual browser, etc.) works over the normal connection as if no VPN existed. The picked apps have no other way to reach the network - so they never see your real IP, not even for a moment.</string>
    <string name="trigger_pick_apps">Pick apps that should use VPN</string>
    <string name="trigger_no_permission">Usage access permission required</string>
    <string name="trigger_grant_permission">Grant usage access</string>
    <string name="trigger_auto_stop">Disconnect tunnel when app is in background (saves battery)</string>
    <string name="trigger_no_profile">No selected server. Select a server first.</string>
    <string name="trigger_always_on_title">Survive NetGuard being killed</string>
    <string name="trigger_always_on_desc">For reliability, in Android system VPN settings enable ONLY \"Always-on VPN\". Do NOT enable \"Block connections without VPN\" - that would also kill normal apps\' internet. Trigger mode already blocks the picked apps whenever the tunnel is down.</string>
    <string name="trigger_open_vpn_settings">Open Android VPN settings</string>
    <string name="trigger_collapse">Hide info</string>
    <string name="trigger_expand">Show info &amp; switches</string>
    <string name="trigger_options_card_title">Trigger options</string>
    <string name="trigger_options_summary_off">Disabled · tap to set up</string>
    <string name="trigger_options_summary_on">Enabled · %1$s · %2$d apps</string>
    <string name="trigger_mode_strict">strict</string>
    <string name="trigger_mode_flexible">flexible</string>
    <string name="trigger_perapp_conflict">Per-App routing was enabled - Trigger mode handles routing by itself. Per-App switched to DISABLED.</string>
    <string name="trigger_strict_mode">Strict allow-list mode</string>
    <string name="trigger_strict_mode_desc">ON: only trigger apps go through VPN, with no fallback path. OFF: trigger apps just decide WHEN the tunnel comes up - routing then follows your normal Per-App / Global setting (whitelist / blacklist / all-apps).</string>
    <string name="trigger_dualapp_warning">⚠ Cloned apps (MIUI Dual Apps / Samsung Dual Messenger / Parallel Space) are not supported by Android\'s VPN API. Use the original Telegram or disable trigger mode for it.</string>
    <string name="trigger_dualapp_more">Why?</string>
    <string name="trigger_dualapp_explain_title">Cloned apps and the VPN API</string>
    <string name="trigger_dualapp_explain_body">Android limitation: a system VPN running in the primary user can only allow-list apps installed for that user. A cloned/dual-app variant runs as a separate user (often UID 999000+ on MIUI) - its UID isn\'t in the allow list, so traffic is dropped and the app shows \"Waiting for network\".\n\nWorkarounds:\n• Use the original (non-cloned) Telegram inside trigger mode.\n• Disable \"Block connections without VPN\" in Android system settings - the cloned variant will then bypass the VPN and use the normal connection.\n• Add the cloned package separately if your system exposes it (rare).</string>

