<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Default Dark -->
    <style name="Theme.NetGuard" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">#7C4DFF</item>
        <item name="colorPrimaryContainer">#3700B3</item>
        <item name="colorSecondary">#BB86FC</item>
        <item name="colorSecondaryContainer">#4A148C</item>
        <item name="colorSurface">#1C1B1F</item>
        <item name="colorSurfaceVariant">#2C2C2C</item>
        <item name="colorOnSurface">#E6E1E5</item>
        <item name="colorOnSurfaceVariant">#CAC4D0</item>
        <item name="colorOutline">#49454F</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Light -->
    <style name="Theme.NetGuard.Light" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">#6200EE</item>
        <item name="colorPrimaryContainer">#E8DEF8</item>
        <item name="colorSecondary">#625B71</item>
        <item name="colorSecondaryContainer">#E8DEF8</item>
        <item name="colorSurface">#FFFBFE</item>
        <item name="colorSurfaceVariant">#F3EDF7</item>
        <item name="colorOnSurface">#1C1B1F</item>
        <item name="colorOnSurfaceVariant">#49454F</item>
        <item name="colorOutline">#CAC4D0</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- OLED Black — pure black for AMOLED displays -->
    <style name="Theme.NetGuard.OLED" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">#BB86FC</item>
        <item name="colorPrimaryContainer">#3700B3</item>
        <item name="colorSecondary">#03DAC6</item>
        <item name="colorSecondaryContainer">#005047</item>
        <item name="colorSurface">#000000</item>
        <item name="colorSurfaceVariant">#0D0D0D</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="colorOnSurfaceVariant">#B0B0B0</item>
        <item name="colorOutline">#333333</item>
        <item name="android:colorBackground">@android:color/black</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">#000000</item>
    </style>

    <!-- Dynamic — Material You (Android 12+), DynamicColors overlays this -->
    <style name="Theme.NetGuard.Dynamic" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Ocean — deep blue & cyan -->
    <style name="Theme.NetGuard.Ocean" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">#00BCD4</item>
        <item name="colorPrimaryContainer">#006874</item>
        <item name="colorSecondary">#4DD0E1</item>
        <item name="colorSecondaryContainer">#004D57</item>
        <item name="colorSurface">#0A1929</item>
        <item name="colorSurfaceVariant">#132F4C</item>
        <item name="colorOnSurface">#E3F2FD</item>
        <item name="colorOnSurfaceVariant">#90CAF9</item>
        <item name="colorOutline">#1E4976</item>
        <item name="android:colorBackground">#060E18</item>
        <item name="android:windowBackground">#060E18</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">#060E18</item>
    </style>

</resources>
