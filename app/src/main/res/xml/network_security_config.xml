<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Cloudflare and OVH serve the same speed-test endpoints over HTTPS, so
         they no longer need a cleartext exception. Only speedtest.tele2.net
         does not offer HTTPS and is kept here. Even though this traffic goes
         through the VPN tunnel, narrowing the whitelist reduces the chance of
         an accidental HTTP call leaking metadata inside the tunnel to a
         captive portal or TLS-downgrade attacker on a hostile WiFi. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">speedtest.tele2.net</domain>
    </domain-config>
</network-security-config>
