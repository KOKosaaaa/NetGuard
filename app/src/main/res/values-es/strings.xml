    <string name="onb_finish">Finalizar</string>
    <string name="onb_welcome_title">Bienvenido a NetGuard</string>
    <string name="onb_welcome_subtitle">Acceso cifrado rápido a tu manera</string>
    <string name="onb_welcome_body">NetGuard es un cliente moderno basado en xray-core con enrutamiento selectivo, prueba de velocidad, kill switch, protección contra Wi-Fi gemelo y estadísticas de tráfico. La configuración tarda alrededor de un minuto — todo se puede cambiar después.</string>
    <string name="onb_feature_trigger_title">⚡ Modo disparador</string>
    <string name="onb_feature_trigger">El VPN se activa solo cuando abres una de tus apps elegidas y se desactiva al cerrarla. Banca, mapas, mensajería — todo lo demás sigue por la conexión normal. Las apps disparadoras no tienen otra forma de salir a la red.</string>
    <string name="onb_feature_perapp_title">🎯 VPN por app</string>
    <string name="onb_feature_perapp">Lista blanca/negra clásica de apps que pasan por el túnel.</string>
    <string name="onb_feature_protocols_title">🔐 Protocolos y seguridad</string>
    <string name="onb_feature_protocols">VLESS, VMess, Trojan, Shadowsocks, Hysteria2. Reality, XTLS-Vision, TLS-Fragment, DNS sobre HTTPS, kill switch — todo compatible.</string>
    <string name="onb_mode_title">¿Cómo debe enrutar el tráfico NetGuard?</string>
    <string name="onb_mode_subtitle">Puedes cambiarlo después en Ajustes</string>
    <string name="onb_mode_global">VPN global</string>
    <string name="onb_mode_global_desc">Todas las apps pasan por el VPN. Modo estándar.</string>
    <string name="onb_mode_trigger">Modo disparador (recomendado)</string>
    <string name="onb_mode_trigger_desc">⚠ SOLO las apps de tu lista de disparadores van por el VPN — el túnel se activa al abrir una y se detiene al cerrarla. Todo lo demás (banca, mapas, navegador) sigue por la conexión normal y NUNCA usa el VPN.</string>
    <string name="onb_mode_perapp">VPN por app</string>
    <string name="onb_mode_perapp_desc">Elige manualmente qué apps pasan por el VPN.</string>
    <string name="onb_mode_skip">Decidir después</string>
    <string name="onb_mode_skip_desc">Omitir — lo configuraré desde Ajustes.</string>
    <string name="onb_vpn_title">Permitir conexión VPN</string>
    <string name="onb_vpn_body">Android requiere permiso explícito para crear un túnel VPN. NetGuard no recoge ni transmite tráfico que no hayas configurado.</string>
    <string name="onb_vpn_grant">Conceder permiso VPN</string>
    <string name="onb_vpn_granted">Permiso VPN concedido ✓</string>
    <string name="onb_vpn_denied">Sin permiso el túnel no funcionará — puedes concederlo después en Ajustes</string>
    <string name="onb_usage_title">Acceso de uso para el modo disparador</string>
    <string name="onb_usage_body">El modo disparador necesita detectar cuándo una app elegida pasa al primer plano. Android lo expone vía Acceso de uso — NetGuard lee solo el nombre del paquete y no guarda nada.</string>
    <string name="onb_usage_grant">Abrir ajustes de Acceso de uso</string>
    <string name="onb_usage_granted">Acceso de uso concedido ✓</string>
    <string name="onb_done_title">Todo listo</string>
    <string name="onb_done_body">Listo. En la pantalla principal toca el interruptor grande para conectar, o abre Servidores → ＋ para añadir más perfiles. Las suscripciones se actualizan automáticamente.</string>
    <string name="onb_profile_title">Añade tu primer servidor</string>
    <string name="onb_profile_body">Pega un enlace vless://, vmess://, trojan://, ss:// o hy2://. También puedes omitir y añadir servidores después.</string>
    <string name="onb_profile_paste">Pegar del portapapeles</string>
    <string name="onb_profile_hint">Pega un enlace de conexión…</string>
    <string name="onb_profile_import">Importar</string>
    <string name="onb_profile_added">%d servidor(es) importado(s) ✓</string>
    <string name="onb_profile_error">No se pudo analizar: %s</string>
    <string name="onb_profile_empty">Portapapeles vacío</string>
    <string name="onb_profile_skip">Añadiré un servidor después</string>
    <string name="trigger_strict_mode">Modo estricto de lista permitida</string>
    <string name="trigger_strict_mode_desc">ON: solo las apps disparadoras pasan por el VPN, sin alternativa. OFF: las apps disparadoras solo deciden CUÁNDO se activa el túnel — el enrutamiento sigue tus ajustes Por-App / Global normales.</string>
    <string name="trigger_dualapp_warning">⚠ Las apps clonadas (MIUI Dual Apps / Samsung Dual Messenger / Parallel Space) no son compatibles con la API VPN de Android.</string>
    <string name="trigger_dualapp_more">¿Por qué?</string>
    <string name="trigger_dualapp_explain_title">Apps clonadas y la API VPN</string>
    <string name="trigger_dualapp_explain_body">Limitación de Android: un VPN del sistema corriendo como usuario principal solo puede permitir apps de ese usuario. Una app clonada funciona como otro usuario (a menudo UID 999000+ en MIUI) — su UID no está en la lista permitida y el tráfico se descarta.\n\nSoluciones:\n• Usa el Telegram original (no clonado) en modo disparador.\n• Desactiva «Bloquear conexiones sin VPN» en Ajustes de Android.\n• Añade el clon por separado si tu sistema lo expone (raro).</string>
</resources>
