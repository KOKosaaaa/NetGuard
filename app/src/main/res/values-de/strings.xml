    <!-- Onboarding -->
    <string name="onb_lang_title">Sprache auswählen</string>
    <string name="onb_lang_subtitle">Lässt sich später in den Einstellungen ändern</string>
    <string name="onb_skip">Überspringen</string>
    <string name="onb_next">Weiter</string>
    <string name="onb_back">Zurück</string>
    <string name="onb_finish">Fertig</string>
    <string name="onb_welcome_title">Willkommen bei NetGuard</string>
    <string name="onb_welcome_subtitle">Schneller verschlüsselter Zugang nach deinen Regeln</string>
    <string name="onb_welcome_body">NetGuard ist ein moderner xray-core-Client mit selektivem Routing, Geschwindigkeitstest, Kill-Switch, Schutz vor gefährlichen WLANs und Verkehrsstatistiken. Das Setup dauert ca. eine Minute — alles lässt sich später ändern.</string>
    <string name="onb_feature_trigger_title">⚡ Trigger-Modus</string>
    <string name="onb_feature_trigger">VPN startet nur, wenn eine ausgewählte App geöffnet wird, und stoppt beim Schließen. Banking, Karten, Lieferdienste — alles andere bleibt auf der normalen Verbindung. Trigger-Apps haben keinen anderen Weg ins Netz.</string>
    <string name="onb_feature_perapp_title">🎯 Per-App VPN</string>
    <string name="onb_feature_perapp">Klassische Whitelist/Blacklist von Apps, die durch den Tunnel laufen.</string>
    <string name="onb_feature_protocols_title">🔐 Protokolle &amp; Sicherheit</string>
    <string name="onb_feature_protocols">VLESS, VMess, Trojan, Shadowsocks, Hysteria2. Reality, XTLS-Vision, TLS-Fragment, DNS-over-HTTPS, Kill-Switch — alles unterstützt.</string>
    <string name="onb_mode_title">Wie soll NetGuard den Verkehr leiten?</string>
    <string name="onb_mode_subtitle">Lässt sich später in den Einstellungen ändern</string>
    <string name="onb_mode_global">Globales VPN</string>
    <string name="onb_mode_global_desc">Alle Apps gehen durch das VPN. Standardmodus.</string>
    <string name="onb_mode_trigger">Trigger-Modus (empfohlen)</string>
    <string name="onb_mode_trigger_desc">⚠ NUR die Apps in deiner Trigger-Liste laufen über VPN — der Tunnel aktiviert sich beim Öffnen und stoppt beim Schließen. Alles andere (Banking, Karten, Browser) bleibt direkt und nutzt nie das VPN.</string>
    <string name="onb_mode_perapp">Per-App VPN</string>
    <string name="onb_mode_perapp_desc">Wähle manuell, welche Apps durch das VPN laufen.</string>
    <string name="onb_mode_skip">Später entscheiden</string>
    <string name="onb_mode_skip_desc">Überspringen — ich konfiguriere es in den Einstellungen.</string>
    <string name="onb_vpn_title">VPN-Verbindung erlauben</string>
    <string name="onb_vpn_body">Android verlangt eine ausdrückliche Erlaubnis für den VPN-Tunnel. NetGuard sammelt oder überträgt keinen Verkehr, den du nicht konfiguriert hast.</string>
    <string name="onb_vpn_grant">VPN-Berechtigung erteilen</string>
    <string name="onb_vpn_granted">VPN-Berechtigung erteilt ✓</string>
    <string name="onb_vpn_denied">Ohne Berechtigung läuft der Tunnel nicht — du kannst sie später erteilen</string>
    <string name="onb_usage_title">Nutzungszugriff für den Trigger-Modus</string>
    <string name="onb_usage_body">Der Trigger-Modus muss erkennen, wann eine ausgewählte App in den Vordergrund kommt. Android liefert das über „Nutzungszugriff" — NetGuard liest nur den Paketnamen und speichert nichts.</string>
    <string name="onb_usage_grant">Einstellungen für Nutzungszugriff öffnen</string>
    <string name="onb_usage_granted">Nutzungszugriff erteilt ✓</string>
    <string name="onb_done_title">Alles bereit</string>
    <string name="onb_done_body">Auf dem Startbildschirm den großen Schalter zum Verbinden tippen, oder Server → ＋ für weitere Profile. Abos aktualisieren sich automatisch.</string>
    <string name="onb_profile_title">Ersten Server hinzufügen</string>
    <string name="onb_profile_body">Füge unten einen vless://-, vmess://-, trojan://-, ss:// oder hy2://-Link ein. Du kannst auch überspringen und Server später hinzufügen.</string>
    <string name="onb_profile_paste">Aus Zwischenablage einfügen</string>
    <string name="onb_profile_hint">Verbindungslink einfügen…</string>
    <string name="onb_profile_import">Importieren</string>
    <string name="onb_profile_added">%d Server importiert ✓</string>
    <string name="onb_profile_error">Konnte nicht analysiert werden: %s</string>
    <string name="onb_profile_empty">Zwischenablage ist leer</string>
    <string name="onb_profile_skip">Server später hinzufügen</string>
    <string name="trigger_strict_mode">Strenger Allow-List-Modus</string>
    <string name="trigger_strict_mode_desc">EIN: Nur Trigger-Apps gehen durch das VPN, ohne Ausweichweg. AUS: Trigger-Apps entscheiden nur, WANN der Tunnel hochkommt — das Routing folgt dann den Per-App-/Globalen Einstellungen.</string>
    <string name="trigger_dualapp_warning">⚠ Geklonte Apps (MIUI Dual Apps / Samsung Dual Messenger / Parallel Space) werden von der Android-VPN-API nicht unterstützt.</string>
    <string name="trigger_dualapp_more">Warum?</string>
    <string name="trigger_dualapp_explain_title">Geklonte Apps und die VPN-API</string>
    <string name="trigger_dualapp_explain_body">Android-Beschränkung: Ein System-VPN im Hauptbenutzer kann nur Apps dieses Benutzers auf die Allow-List setzen. Eine geklonte App läuft als separater Benutzer (oft UID 999000+ auf MIUI) — ihre UID ist nicht in der Allow-List, Verkehr wird verworfen.\n\nLösungen:\n• Verwende den originalen Telegram im Trigger-Modus.\n• Deaktiviere „Verbindungen ohne VPN blockieren" in den Android-Einstellungen.\n• Falls dein System den Klon als separates Paket zeigt — füge ihn extra hinzu (selten).</string>
</resources>
