    <!-- Onboarding -->
    <string name="onb_lang_title">Pilih bahasa Anda</string>
    <string name="onb_lang_subtitle">Dapat diubah nanti di Pengaturan</string>
    <string name="onb_skip">Lewati</string>
    <string name="onb_next">Lanjut</string>
    <string name="onb_back">Kembali</string>
    <string name="onb_finish">Selesai</string>
    <string name="onb_welcome_title">Selamat datang di NetGuard</string>
    <string name="onb_welcome_subtitle">Akses terenkripsi cepat dengan cara Anda</string>
    <string name="onb_welcome_body">NetGuard adalah klien xray-core modern dengan perutean selektif, uji kecepatan, kill switch, perlindungan Wi-Fi kembar, dan statistik trafik. Pengaturan memakan waktu sekitar satu menit — semuanya dapat diubah nanti.</string>
    <string name="onb_feature_trigger_title">⚡ Mode pemicu</string>
    <string name="onb_feature_trigger">VPN aktif hanya saat Anda membuka salah satu aplikasi pilihan dan berhenti diam-diam saat ditutup. Bank, peta, pengiriman — semua lainnya tetap pada koneksi normal.</string>
    <string name="onb_feature_perapp_title">🎯 VPN per aplikasi</string>
    <string name="onb_feature_perapp">Whitelist/blacklist klasik aplikasi yang melewati terowongan.</string>
    <string name="onb_feature_protocols_title">🔐 Protokol &amp; keamanan</string>
    <string name="onb_feature_protocols">VLESS, VMess, Trojan, Shadowsocks, Hysteria2. Reality, XTLS-Vision, TLS-Fragment, DNS-over-HTTPS, kill switch — semuanya didukung.</string>
    <string name="onb_mode_title">Bagaimana NetGuard merutekan trafik?</string>
    <string name="onb_mode_subtitle">Dapat diubah nanti di Pengaturan</string>
    <string name="onb_mode_global">VPN global</string>
    <string name="onb_mode_global_desc">Semua aplikasi melewati VPN. Mode standar.</string>
    <string name="onb_mode_trigger">Mode pemicu (direkomendasikan)</string>
    <string name="onb_mode_trigger_desc">⚠ HANYA aplikasi dalam daftar pemicu yang melewati VPN — terowongan diaktifkan saat dibuka dan berhenti saat ditutup. Yang lain (bank, peta, browser) tetap pada koneksi normal dan TIDAK PERNAH menggunakan VPN.</string>
    <string name="onb_mode_perapp">VPN per aplikasi</string>
    <string name="onb_mode_perapp_desc">Pilih secara manual aplikasi mana yang melewati VPN.</string>
    <string name="onb_mode_skip">Putuskan nanti</string>
    <string name="onb_mode_skip_desc">Lewati — saya akan mengonfigurasi dari Pengaturan.</string>
    <string name="onb_vpn_title">Izinkan koneksi VPN</string>
    <string name="onb_vpn_body">Android memerlukan izin eksplisit untuk membuat terowongan VPN. NetGuard tidak mengumpulkan atau mengirim trafik apa pun yang tidak Anda konfigurasi.</string>
    <string name="onb_vpn_grant">Berikan izin VPN</string>
    <string name="onb_vpn_granted">Izin VPN diberikan ✓</string>
    <string name="onb_vpn_denied">Tanpa izin terowongan tidak akan berfungsi — Anda dapat memberikannya nanti</string>
    <string name="onb_usage_title">Akses penggunaan untuk mode pemicu</string>
    <string name="onb_usage_body">Mode pemicu perlu mendeteksi kapan aplikasi pilihan ke depan. Android menyediakan ini melalui pengaturan Akses Penggunaan — NetGuard hanya membaca nama paket dan tidak menyimpan apa pun.</string>
    <string name="onb_usage_grant">Buka pengaturan Akses Penggunaan</string>
    <string name="onb_usage_granted">Akses diberikan ✓</string>
    <string name="onb_done_title">Semua siap</string>
    <string name="onb_done_body">Siap. Di layar utama ketuk sakelar besar untuk terhubung, atau buka Server → ＋ untuk menambah profil. Langganan diperbarui otomatis.</string>
    <string name="onb_profile_title">Tambahkan server pertama Anda</string>
    <string name="onb_profile_body">Tempel tautan vless://, vmess://, trojan://, ss:// atau hy2:// di bawah. Anda juga bisa melewati dan menambahkan server nanti.</string>
    <string name="onb_profile_paste">Tempel dari papan klip</string>
    <string name="onb_profile_hint">Tempel tautan koneksi…</string>
    <string name="onb_profile_import">Impor</string>
    <string name="onb_profile_added">%d server diimpor ✓</string>
    <string name="onb_profile_error">Tidak bisa diurai: %s</string>
    <string name="onb_profile_empty">Papan klip kosong</string>
    <string name="onb_profile_skip">Saya akan menambahkan server nanti</string>
    <string name="trigger_strict_mode">Mode daftar izin ketat</string>
    <string name="trigger_strict_mode_desc">ON: hanya aplikasi pemicu melewati VPN, tanpa alternatif. OFF: aplikasi pemicu hanya menentukan KAPAN terowongan aktif — perutean mengikuti pengaturan Per-Aplikasi/Global normal Anda.</string>
    <string name="trigger_dualapp_warning">⚠ Aplikasi tiruan (MIUI Dual Apps / Samsung Dual Messenger / Parallel Space) tidak didukung oleh API VPN Android.</string>
    <string name="trigger_dualapp_more">Mengapa?</string>
    <string name="trigger_dualapp_explain_title">Aplikasi tiruan dan API VPN</string>
    <string name="trigger_dualapp_explain_body">Batasan Android: VPN sistem yang berjalan di pengguna utama hanya bisa mengizinkan aplikasi pengguna tersebut. Aplikasi tiruan berjalan sebagai pengguna terpisah (sering UID 999000+ di MIUI) — UID-nya tidak ada di daftar izin sehingga trafik dibuang.\n\nSolusi:\n• Gunakan Telegram asli (bukan tiruan) di mode pemicu.\n• Nonaktifkan «Blokir koneksi tanpa VPN» di pengaturan Android.\n• Tambahkan tiruan secara terpisah jika sistem Anda menampilkannya (jarang).</string>
</resources>
