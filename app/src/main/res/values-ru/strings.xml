    <!-- Onboarding -->
    <string name="onb_lang_title">Выбери язык</string>
    <string name="onb_lang_subtitle">Можно поменять позже в настройках</string>
    <string name="onb_skip">Пропустить</string>
    <string name="onb_next">Далее</string>
